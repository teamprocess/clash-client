{
  "name": "clash-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @clash/mac dev",
    "dev:mac": "pnpm --filter @clash/mac dev",
    "dev:web": "pnpm --filter @clash/web dev",
    "build": "pnpm --filter @clash/mac build",
    "build:mac": "pnpm --filter @clash/mac build",
    "build:web": "pnpm --filter @clash/web build",
    "preview": "pnpm --filter @clash/mac build && pnpm --filter @clash/mac start -- --skipBuild",
    "preview:mac": "pnpm --filter @clash/mac build && pnpm --filter @clash/mac start -- --skipBuild",
    "preview:web": "pnpm --filter @clash/web build && pnpm --filter @clash/web start -- --skipBuild",
    "start": "pnpm --filter @clash/mac start",
    "start:mac": "pnpm --filter @clash/mac start",
    "start:web": "pnpm --filter @clash/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
