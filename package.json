{
  "name": "clash-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev --parallel",
    "dev:mac": "pnpm --filter @clash/mac dev",
    "dev:web": "pnpm --filter @clash/web dev",
    "build": "turbo run build",
    "build:mac": "pnpm --filter @clash/mac build",
    "build:web": "pnpm --filter @clash/web build",
    "release:mac": "pnpm --filter @clash/mac run release:mac",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.5.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm exec eslint --fix --cache",
      "pnpm exec prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  }
}
